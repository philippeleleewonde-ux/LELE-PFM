{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": false,               // ✅ Vérifie les types des librairies

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - CONFIGURATION STRICTE NIVEAU ENTERPRISE */
    "strict": true,                      // ✅ Mode strict complet
    "noUnusedLocals": true,              // ✅ Variables inutilisées = ERREUR
    "noUnusedParameters": true,          // ✅ Paramètres inutilisés = ERREUR
    "noImplicitAny": true,               // ✅ Any implicite = ERREUR
    "noFallthroughCasesInSwitch": true,  // ✅ Switch sans break = ERREUR
    "noImplicitReturns": true,           // ✅ Fonctions sans return = ERREUR
    "noImplicitThis": true,              // ✅ This implicite = ERREUR
    "noUncheckedIndexedAccess": true,    // ✅ Accès array/object sécurisés

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
