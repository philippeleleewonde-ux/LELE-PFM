# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Sentry Error Tracking (Optional but HIGHLY recommended for production)
# Get your DSN from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
VITE_SENTRY_DSN=

# Force Sentry in development (for testing)
# VITE_SENTRY_FORCE_DEV=true

# Data Extractor V2 - LLM Configuration
# Get Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: OpenAI API key (fallback for BusinessLinesRegrouper)
# OPENAI_API_KEY=your-openai-api-key-here

# Supabase Service Role Key (backend only, NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
